---
import Layout from "@/layouts/Layout.astro";

interface Props {
  title: string;
  description?: string;
  byline: string;
  backHref: string;
  backLabel: string;
}

const { title, description, byline, backHref, backLabel } = Astro.props;
---

<Layout title={title} description={description}>
  <main>
    <p>
      <a href={backHref} class="group">
        <span class="animate-arrow-spring">&larr;</span>
        {backLabel}
      </a>
    </p>
    <h1>{title}</h1>
    <p>{byline}</p>
    <hr />
    <slot />
  </main>
</Layout>

<style>
  /* Long entry titles read better a notch below the default h1 scale. */
  h1 {
    font-size: 1.5em;
    margin-bottom: 0.5em;
  }
</style>
