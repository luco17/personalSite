---
import Nav from "../components/Nav.astro";
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Welcome! I hope you find something of interest here. Lucien"
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/weaselOg.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script defer data-domain="lcod.uk" src="https://plausible.io/js/script.js"
    ></script>
  </head>
  <body>
    <Nav />
    <slot />
  </body>
</html>
