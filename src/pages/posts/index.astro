---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { byDateDesc } from "../../lib/sort";

const allPosts = await getCollection("posts");
---

<Layout title="LOD - Posts" description="The occasional article.">
  <main>
    <h1>Posts</h1>
    <hr />
    <ul>
      {
        allPosts
        .sort(byDateDesc)
        .map((post) => (
        <li>
          <a href={`/posts/${post.id}/`} data-astro-prefetch>{post.data.title}</a>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>

<style>
  ul {
    padding-left: 1rem;
  }

  li {
    padding: 4px 0;
  }
</style>
