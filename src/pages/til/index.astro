---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { byDateDesc } from "../../lib/sort";

const allTil = await getCollection("til");
---

<Layout title="LOD - TIL" description="Things I learned today.">
  <main>
    <h1>TIL</h1>
    <p>Things I learned today.</p>
    <hr />
    <ul>
      {
        allTil
        .sort(byDateDesc)
        .map((til) => (
          <li>
            <a href={`/til/${til.id}/`} data-astro-prefetch>{til.data.title}</a>
            <span class="date"> - {til.data.date.toDateString()}</span>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>

<style>
  ul {
    padding-left: 1rem;
  }

  li {
    padding: 4px 0;
  }

  .date {
    font-size: 0.8rem;
    color: darkslategrey;
  }

  @media (prefers-color-scheme: dark) {
    .date {
      color: ghostwhite;
    }
  }
</style>
