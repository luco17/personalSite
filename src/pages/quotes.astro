---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";

// File order is curation order; ids make it explicit.
const quotes = (await getCollection("quotes")).sort(
  (a, b) => Number(a.id) - Number(b.id),
);
---

<Layout title="LOD - Quotes" description="Quotes worth keeping.">
  <main>
    <h1>Quotes</h1>
    <hr />
    {
      quotes.map((quote) => (
        <p>
          <em>{quote.data.text}</em> ~ {quote.data.attribution}
        </p>
      ))
    }
  </main>
</Layout>
