---
import Layout from "@/layouts/Layout.astro";

// Force SSR mode
export const prerender = false;

const { searchParams } = Astro.url;
const nParam = searchParams.get("n");
const n = nParam ? parseInt(nParam, 10) : 20;

let posts = [];
let errorMsg = "";

try {
  const db = Astro.locals.runtime?.env?.pensieve_db;
  if (!db) {
    throw new Error("pensieve_db binding is missing. Ensure the D1 binding is configured in Cloudflare.");
  }
  
  const { results } = await db
    .prepare("SELECT id, content, created_at, source FROM brain_dump WHERE is_hidden = 0 ORDER BY created_at DESC LIMIT ?")
    .bind(n)
    .all();
    
  posts = results || [];
} catch (e: any) {
  console.error("D1 Fetch Error:", e);
  errorMsg = e.message;
}

const formatDate = (dateStr: string) => {
  try {
    const d = new Date(dateStr);
    if (isNaN(d.getTime())) return dateStr;
    const formattedDate = d.toLocaleDateString("en-GB", {
      day: "2-digit",
      month: "short",
      year: "numeric",
    });
    const formattedTime = d.toLocaleTimeString("en-GB", {
      hour: "2-digit",
      minute: "2-digit",
    });
    return `${formattedDate}, ${formattedTime}`;
  } catch {
    return dateStr;
  }
};
---

<Layout title="LOD - Wall" description="Live stream of thoughts and notes captured from Telegram and CLI.">
  <main>
    <header>
      <div class="title-bar">
        <h1>Wall</h1>
        <button id="refresh-btn" class="refresh-trigger">refresh</button>
      </div>
    </header>

    {errorMsg && (
      <div class="error-banner">
        <strong>Database Connection Error:</strong>
        <p>{errorMsg}</p>
      </div>
    )}

    {!errorMsg && posts.length === 0 && (
      <p class="empty-state">No thoughts captured yet. Send some notes via pensieve CLI or Telegram.</p>
    )}

    {!errorMsg && posts.length > 0 && (
      <div class="stack">
        {posts.map((post) => (
          <article class="post-item">
            <div class="post-header">
              <time class="post-date">{formatDate(post.created_at)}</time>
              <span>•</span>
              <span class="post-source">via {post.source}</span>
            </div>
            <div class="post-body">{post.content}</div>
          </article>
        ))}
      </div>
    )}

    <footer class="footer-controls">
      <span>Thoughts captured live</span>
      <div class="limit-links">
        <span>limit:</span>
        <a href="?n=10" class={`limit-link ${n === 10 ? 'active' : ''}`}>10</a>
        <a href="?n=20" class={`limit-link ${n === 20 ? 'active' : ''}`}>20</a>
        <a href="?n=50" class={`limit-link ${n === 50 ? 'active' : ''}`}>50</a>
        <a href="?n=100" class={`limit-link ${n === 100 ? 'active' : ''}`}>100</a>
      </div>
    </footer>
  </main>
</Layout>

<script>
  // Handle refresh button click
  const refreshBtn = document.getElementById("refresh-btn");
  if (refreshBtn) {
    refreshBtn.addEventListener("click", () => {
      window.location.reload();
    });
  }
</script>

<style>
  main {
    margin-block: 1rem;
  }

  header {
    margin-bottom: 1.5rem;
  }

  .title-bar {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.5rem;
  }

  h1 {
    font-size: 1.35rem;
    font-weight: 600;
    margin: 0;
  }

  .refresh-trigger {
    font-size: 0.8rem;
    color: var(--muted);
    text-decoration: none;
    border-top: none;
    border-left: none;
    border-right: none;
    border-bottom: 1px dashed var(--muted);
    background: transparent;
    padding: 0;
    cursor: pointer;
    font-family: inherit;
  }

  .refresh-trigger:hover {
    color: var(--color);
    border-bottom-color: var(--color);
  }

  /* Compact Stack List */
  .stack {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
  }

  .post-item {
    padding-block: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .post-item:first-of-type {
    padding-top: 0.5rem;
  }

  .post-item:last-of-type {
    border-bottom: none;
  }

  .post-header {
    font-size: 0.8rem;
    color: var(--muted);
    margin-bottom: 0.4rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .post-source {
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.05em;
    font-size: 0.72rem;
  }

  .post-body {
    white-space: pre-wrap;
    line-height: 1.45;
  }

  /* Error Banner */
  .error-banner {
    background: #fff0f0;
    border-left: 4px solid #ff3b30;
    padding: 0.75rem 1rem;
    margin: 1rem 0;
    border-radius: 4px;
    color: #8b0000;
    font-size: 0.95rem;
  }

  .error-banner p {
    margin: 0.25rem 0 0 0;
  }

  .empty-state {
    font-style: italic;
    color: var(--muted);
    text-align: center;
    margin: 2rem 0;
  }

  /* Footer Controls */
  .footer-controls {
    margin-top: 2rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .limit-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .limit-link {
    color: var(--muted);
    text-decoration: none;
    padding: 0.1rem 0.3rem;
  }

  .limit-link.active {
    color: var(--color);
    font-weight: bold;
    text-decoration: underline;
  }

  .limit-link:hover {
    color: var(--color);
  }

  /* Dark Mode Support overrides */
  @media (prefers-color-scheme: dark) {
    .error-banner {
      background: #2a1111;
      color: #ffb3b3;
      border-left-color: #ff453a;
    }
  }
</style>
