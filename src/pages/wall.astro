---
import Layout from "@/layouts/Layout.astro";
import { env } from "cloudflare:workers";

type WallPost = {
  id: number;
  content: string;
  created_at: string;
};

const pageSize = 50;

const parseCreatedAt = (value: string) => {
  const isoValue = value.includes("T") ? value : `${value.replace(" ", "T")}Z`;
  const date = new Date(isoValue);
  return Number.isNaN(date.getTime()) ? null : date;
};

const formatDate = (value: string) => {
  const date = parseCreatedAt(value);
  if (!date) return value;

  const formattedDate = date.toLocaleDateString("en-GB", {
    day: "2-digit",
    month: "short",
    year: "numeric",
    timeZone: "Europe/London",
  });
  const formattedTime = date.toLocaleTimeString("en-GB", {
    hour: "2-digit",
    minute: "2-digit",
    timeZone: "Europe/London",
  });
  return `${formattedDate}, ${formattedTime}`;
};

const dateTimeAttribute = (value: string) => parseCreatedAt(value)?.toISOString();

const parseBefore = (value: string | null) => {
  if (!value) return null;

  const date = parseCreatedAt(value);
  if (!date) return null;

  return value.includes("T")
    ? date.toISOString().replace("T", " ").slice(0, 19)
    : value;
};

const escapeHtml = (value: string) =>
  value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;");

const trailingUrlPunctuation = /[),.;:!?]+$/;
const urlPattern = /https?:\/\/[^\s<>"']+/g;

const linkify = (value: string) =>
  escapeHtml(value).replace(urlPattern, (url) => {
    const punctuation = url.match(trailingUrlPunctuation)?.[0] ?? "";
    const href = url.slice(0, url.length - punctuation.length);
    return `<a href="${href}">${href}</a>${punctuation}`;
  });

const wallPostsQuery = `
  SELECT id, content, created_at
  FROM entries
  WHERE hidden_at IS NULL AND (? IS NULL OR created_at < ?)
  ORDER BY created_at DESC
  LIMIT ?
`;

export const prerender = false;

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=30, stale-while-revalidate=300",
);

const before = parseBefore(Astro.url.searchParams.get("before"));
let posts: WallPost[] = [];
let errorMsg = "";

try {
  const { results } = await env.pensieve_db
    .prepare(wallPostsQuery)
    .bind(before, before, pageSize)
    .all<WallPost>();

  posts = results;
} catch (error: unknown) {
  console.error("Wall entries could not be loaded", error);
  errorMsg = "The wall is temporarily unavailable.";
}

const oldestPost = posts.at(-1);
const olderUrl = oldestPost
  ? `/wall?before=${encodeURIComponent(oldestPost.created_at)}`
  : null;
const moreRecentUrl = before ? "/wall" : null;
---

<Layout title="LOD - Wall" description="Recent notes and clips.">
  <main class="wall">
    <h1>Wall</h1>
    <hr />

    {errorMsg && (
      <div class="error-banner" role="status">
        <p>{errorMsg}</p>
      </div>
    )}

    {!errorMsg && posts.length === 0 && (
      <p class="empty-state">No notes yet.</p>
    )}

    {!errorMsg && posts.length > 0 && (
      <div class="stack">
        {posts.map((post) => (
          <article class="post-item">
            <div class="post-header">
              <time class="post-date" datetime={dateTimeAttribute(post.created_at)}>
                {formatDate(post.created_at)}
              </time>
            </div>
            <div class="post-body" set:html={linkify(post.content)} />
          </article>
        ))}
      </div>
    )}

    <footer class="footer-controls">
      {moreRecentUrl && (
        <a class="wall-page-link" href={moreRecentUrl}>&larr; More recent</a>
      )}
      {olderUrl && (
        <a class="wall-page-link older-link" href={olderUrl}>Older &rarr;</a>
      )}
    </footer>
  </main>
</Layout>

<style>
  .wall {
    font-size: 1rem;
    margin-block: 1rem;
  }

  h1 {
    font-weight: 600;
  }

  .stack {
    margin-top: 1.5rem;
  }

  .post-item {
    margin-block: 0;
    padding-block: 1.25rem;
    border-bottom: 1px solid #ececec;
  }

  .post-item:first-of-type {
    padding-top: 0;
  }

  .post-item:last-of-type {
    border-bottom: none;
  }

  .post-header {
    color: #777;
    font-family:
      ui-monospace, SFMono-Regular, "SF Mono", Menlo, Monaco, Consolas,
      monospace;
    font-size: 0.75rem;
    margin-bottom: 0.4rem;
  }

  .post-body {
    white-space: pre-wrap;
    line-height: 1.45;
  }

  .error-banner {
    background: #fff0f0;
    border-left: 4px solid #ff3b30;
    padding: 0.75rem 1rem;
    margin: 1rem 0;
    border-radius: 4px;
    color: #8b0000;
    font-size: 0.95rem;
  }

  .error-banner p {
    margin: 0.25rem 0 0 0;
  }

  .empty-state {
    font-style: italic;
    color: var(--muted);
    text-align: center;
    margin: 2rem 0;
  }

  .footer-controls {
    margin-top: 2rem;
    padding-top: 0.85rem;
    border-top: 1px solid #ececec;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.78rem;
    color: #777;
  }

  .footer-controls a {
    border-radius: 999px;
    color: #777;
    line-height: 1;
    padding: 0.35rem 0.55rem;
    text-decoration: none;
  }

  .footer-controls a:visited {
    color: #777;
  }

  .footer-controls a:hover {
    background: #f6f6f6;
    color: #111;
  }

  .older-link {
    margin-left: auto;
  }

  @media (prefers-color-scheme: dark) {
    .post-item,
    .footer-controls {
      border-color: #222;
    }

    .post-header,
    .footer-controls,
    .footer-controls a,
    .footer-controls a:visited {
      color: #888;
    }

    .footer-controls a:hover {
      background: #1b1b1b;
      color: #fff;
    }

    .error-banner {
      background: #2a1111;
      color: #ffb3b3;
      border-left-color: #ff453a;
    }
  }
</style>
