---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";

// Newest month first; ids preserve curation order within a month.
const links = (await getCollection("links")).sort(
  (a, b) =>
    b.data.month.localeCompare(a.data.month) || Number(a.id) - Number(b.id),
);
const months = [...new Set(links.map((link) => link.data.month))];

const monthLabel = (month: string) =>
  new Date(`${month}-01T00:00:00Z`).toLocaleDateString("en-GB", {
    month: "long",
    year: "numeric",
    timeZone: "UTC",
  });
---

<Layout
  title="LOD - Links"
  description="The best things I've found each month."
>
  <main>
    <h1>Links</h1>
    <p>A List of the best things I've found each month</p>
    <hr />
    {
      months.map((month) => (
        <>
          <h2>{monthLabel(month)}</h2>
          {links
            .filter((link) => link.data.month === month)
            .map((link) => (
              <p>
                <a href={link.data.url}>{link.data.title}</a>
              </p>
            ))}
        </>
      ))
    }
  </main>
</Layout>

<style>
  /* Month headings sit at h2 in the outline but keep the compact look. */
  h2 {
    font-size: 1em;
    margin-block: 1.4em 0.7em;
  }
</style>
